{
  "expo": {
    "name": "Brick ID",
    "slug": "lego_identifier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#CC0000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.legoidentifier.brickid",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Brick ID uses your camera to photograph LEGO pieces for identification.",
        "NSPhotoLibraryUsageDescription": "Brick ID can use photos from your library to identify LEGO pieces."
      }
    },
    "android": {
      "package": "com.legoidentifier.brickid",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#CC0000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Brick ID uses your camera to photograph LEGO pieces for identification."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Brick ID can use photos from your library to identify LEGO pieces."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
